@startuml diagrama_classes_completo
skinparam monochrome true
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 60
skinparam padding 6
skinparam shadowing false
hide empty members

' ============================================================
' ENUMERADORES
' ============================================================

enum ClassificacaoEmprestimo {
  Aberto
  Disponível
  Em uso
  EmDevolucao
}

enum EstadoManutencao {
  Na validade
  Em manutenção
  Fora da validade
}

enum ClassificacaoEPI {
  Proteção contra quedas
  Proteção de membros inferiores
  Proteção de membros superiores
  Proteção de tronco
  Proteção respiratória
  Proteção auditiva
  Proteção dos olhos
  Proteção da face
  Proteção da cabeça
}

enum StatusFuncionario {
  Indisponível
  Disponível
  Em tarefa
  Em férias
  Afastado
}

enum NivelPerigo {
  Baixo
  Médio
  Crítico
}

enum TipoSensor {
  Presença e Proximidade
  Gases
  Qualidade do ar
  Ambientes
  Movimento
  Vibração
  Radiação
}

' ============================================================
' CLASSES — declaradas por ordem de centralidade no grafo
' ============================================================

' Hub central do domínio
class Funcionario {
  - cpf: String
  - nome: String
  - dataAdmissao: Date
  - funcao: String
  - classificacao: StatusFuncionario
  - historicoComportamento: String
  |||
  |||
  + estaApto(): Boolean
  + atualizarStatusAptidao(): void
}

class GestorDeSeguranca {
  - email: String
  - senha: String
  |||
  |||
  |||
}

class Ocorrencia {
  - dataOcorrencia: Date
  - local: String
  - descricao: String
  |||
  |||
}

class EPI {
  - ca: String
  - nome: String
  - status: ClassificacaoEPI
  - validade: Date
  - dataFornecimento: Date
  - dataPrevisaoDescarte: Date
  |||
  |||
  + obterDataValidadeCondicoes(): Boolean
  + verificarValidadeCA(): Boolean
  + atualizarPrevisaoDescarte(): void
}

class AreaDeRisco {
  - nome: String
  - status: NivelPerigo
  |||
  |||
  |||
}

class Setor {
  - nome: String
  - descricao: String
  - localizacao: String
  - status: String
  + obterDadosPlanta(): void
  + validarLimitesSetor(): Boolean
  + validarSaidasCadastradas(): Boolean
  + bloquearZonaDeImpacto(): void
  + verificarRotasUteis(): Boolean
  + aplicarBloqueioTotais(): void
}

class Tarefa {
  - descricao: String
  - status: String
  + validarAlocacaoFuncionario(): Boolean
}

' --- Módulo Segurança ---

class Inspecao {
  - dataInspecao: Date
  - responsavel: String
  - conformidade: Boolean
  - observacoes: String
}

class ItemVerificado {
  - descricao: String
  - dataVerificacao: Date
  - conforme: Boolean
  - observacoes: String
}

class AlertaComportamento {
  - dataEmissao: Date
  - nivelGravidade: String
  - mensagemNotificacao: String
  - lidoPeloGestor: Boolean
}

class AlertaSensor {
  - dataEmissao: Date
  - nivelLeitura: Float
  - mensagem: String
  - lidoPeloGestor: Boolean
}

class PlanoDeAcao {
  - medidasCorretivas: String
  - prazo: Date
  - status: String
  - medidasPreventivas: String
}

class MidiaAnexa {
  - nomeArquivo: String
  - tipoMidia: String
  - caminhoArquivo: String
  - dataUpload: Date
}

' --- Módulo Infraestrutura ---

class Sensor {
  - localizacao: String
  - tipo: TipoSensor
}

class SaidaEmergencia {
  - idSaida: String
  - capacidadeEvacuacao: Integer
  - localizacao: String
  - estaDesobstruida: Boolean
  + definirBloqueio(): void
}

class SimulacaoEmergencia {
  - idSimulacao: String
  - dataRealizacao: Date
  - tempoEvacuacaoPrat: Integer
  - eficacia: String
}

class Vulnerabilidade {
  - descricao: String
  - local: String
}

class ServicoDeRoteamento {
  - reguaVelocidade: Float
  - algoritmoBusca: String
  + executarBuscaDeCaminho(): void
  + calcularTempoEstimado(): Integer
  + identificarGargalos(): void
  + recolocarRotas(): void
  + gerarComparativoRealESimulado(): void
}

class RotaSaida {
  - caminho: String
  - distanciaTotal: Float
  - tempoEstimado: Integer
  - status: String
  + calcularTempoEstimado(): Integer
  + estaBloqueada(): Boolean
}

class Gargalo {
  - localizacao: String
  - descricao: String
  - gravidade: String
}

' --- Módulo Funcionários ---

class Certificacao {
  - nome: String
  - status: String
  - dataVencimento: Date
  - dataEmissao: Date
}

class AtestadoSaude {
  - dataEmissao: Date
  - tipo: String
  - dataVencimento: Date
  - apto: Boolean
}

class Treinamento {
  - nome: String
  - conteudo: String
  - instrutor: String
  - dataRealizacao: Date
  - cargaHoraria: Integer
}

' --- Módulo Ocorrências ---

class Incidente {
  - potencialDano: String
}

class Acidente {
  - causaRaiz: String
  - tipo: String
}

class CAT {
  - numeroProtocolo: String
  - destino: String
}

class OrgaoDestino {
  - nome: String
  - cnpj: String
  - endereco: String
}

class Testemunha {
  - nome: String
  - documentoIdentificacao: String
  - depoimento: String
  - contato: String
}

' --- Módulo Inventário ---

class Emprestimo {
  - dataRetirada: Date
  - dataDevolucaoPrevista: Date
  - dataDevolucaoReal: Date
  - status: ClassificacaoEmprestimo
  + obterHistoricoUsoFrequencia(): void
}

class Fornecedor {
  - cnpj: String
  - razaoSocial: String
  - representante: String
  - email: String
  - telefone: String
}

class EntradaEstoque {
  - numeroNf: String
  - dataFiscal: Date
  - valorUnitario: Float
}

class MovimentacaoEstoque {
  - data: Date
  - quantidade: Integer
  - situacao: String
  - motivo: String
  + atualizarQuantidadeMov(): void
}

class Estoque {
  - quantAtual: Integer
  - quantMinima: Integer
  - localizacao: String
  + compararComQuantMinima(): Boolean
  + validarCustoHistoricoConsumo(): Boolean
}

class ProjecaoSubstituicao {
  - dataProjecao: Date
  - dataEstimadaDescarte: Date
  - quantidadeCalculada: Integer
  - justificativa: String
}

class Manutencao_EPI {
  - dataManutencao: Date
  - descricaoManutencao: String
  - resultadoManutencao: EstadoManutencao
}

' ============================================================
' HERANÇA
' ============================================================

Funcionario <|-up- GestorDeSeguranca
Ocorrencia <|-down- Incidente
Ocorrencia <|-down- Acidente
MovimentacaoEstoque <|-down- EntradaEstoque

' ============================================================
' RELACIONAMENTOS — Segurança e Inspeção
' ============================================================
' GestorDeSeguranca é um hub central e requer muito espaço e links longos

GestorDeSeguranca -up---- "0..*" Inspecao
GestorDeSeguranca -left---- "0..*" AlertaComportamento
GestorDeSeguranca -right---- "0..1" PlanoDeAcao
GestorDeSeguranca -down---- "0..*" AlertaSensor
GestorDeSeguranca -up---- "1..*" AreaDeRisco
GestorDeSeguranca -left---- Treinamento
GestorDeSeguranca -right---- "0..*" MovimentacaoEstoque
GestorDeSeguranca -down---- "0..*" Ocorrencia

Inspecao -- "0..*" ItemVerificado
Inspecao *-- "0..*" MidiaAnexa
Inspecao "0..*" --- "1..*" AreaDeRisco

PlanoDeAcao "0..*" --- "0..*" Ocorrencia

AlertaComportamento "0..*" -- Funcionario

' ============================================================
' RELACIONAMENTOS — Infraestrutura, Setores e Rotas
' ============================================================
' AreaDeRisco é altamente conectada

Setor -- AreaDeRisco
Setor "1..*" --- "1..*" Tarefa
Setor -- "0..*" ServicoDeRoteamento

AreaDeRisco -up---- "0..*" Sensor
AreaDeRisco -left---- "0..*" SaidaEmergencia
AreaDeRisco -right---- "1..*" SimulacaoEmergencia
AreaDeRisco "0..1" -down---- "0..*" Ocorrencia
AreaDeRisco "0..*" -down---- "0..1" Tarefa

Sensor -- "0..*" AlertaSensor

SaidaEmergencia "0..*" --- SimulacaoEmergencia

SimulacaoEmergencia "0..*" --- Vulnerabilidade

ServicoDeRoteamento ..> RotaSaida : <<use>>
ServicoDeRoteamento ..> Gargalo   : <<use>>

RotaSaida *-- "0..*" Gargalo

' ============================================================
' RELACIONAMENTOS — Funcionários e Treinamentos
' ============================================================
' Funcionario é um hub e precisa espalhar conexões

Funcionario -up---- "0..*" Certificacao
Funcionario -left---- "0..*" AtestadoSaude
Funcionario "0..*" -down---- "0..*" Treinamento
Funcionario "1..*" -right---- "0..*" Setor
Funcionario "1..*" -up---- Tarefa
Funcionario -down---- "0..*" Emprestimo

Treinamento -- "1..*" Certificacao

' ============================================================
' RELACIONAMENTOS — Ocorrências
' ============================================================

Funcionario -right---- "0..*" Ocorrencia
Ocorrencia -up---- "0..*" Testemunha
Ocorrencia -right---- "0..*" MidiaAnexa
Ocorrencia "0..*" -down---- "0..*" EPI
Ocorrencia "0..*" -left---- "0..1" Tarefa

Acidente -- "0..1" CAT
CAT "1..*" -- OrgaoDestino

' ============================================================
' RELACIONAMENTOS — EPI e Inventário
' ============================================================
' EPI é muito conectado

EPI -up---- "0..*" Emprestimo
EPI "1..*" -right---- "1..*" Fornecedor
EPI -down---- "0..*" ProjecaoSubstituicao
EPI -left---- "0..*" Manutencao_EPI
EPI -left----- "0..*" Tarefa

Estoque *-- "1..*" EPI
Estoque -- "0..*" MovimentacaoEstoque

Fornecedor -- "0..*" EntradaEstoque

@enduml
