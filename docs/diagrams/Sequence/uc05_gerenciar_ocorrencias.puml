@startuml
skinparam monochrome true
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultFontSize 14
skinparam roundcorner 10
skinparam maxmessagesize 120

actor "GestorDeSeguranca" as Gestor
participant "Painel Ocorrências" as UI
participant "Ocorrencia" as Ocorrencia
participant "Funcionario" as Funcionario
database "Banco de Dados" as DB

Gestor -> UI : Acessar gerenciamento
UI --> Gestor : Apresentar opções

alt Fluxo Principal: Cadastrar Ocorrência
  Gestor -> UI : Escolher cadastrar e preencher
  UI -> Funcionario : verificarAptidao(cpf)
  Funcionario -> DB : buscarFuncionario()
  DB --> Funcionario : dados
  Funcionario --> UI : funcionarioValido
  UI -> Ocorrencia : criarNova(dados)
  alt Tipo == Acidente
    Ocorrencia -> Ocorrencia : instanciarAcidente()
  else Tipo == Incidente
    Ocorrencia -> Ocorrencia : instanciarIncidente()
  end
  Ocorrencia -> DB : salvar()
  Ocorrencia --> UI : idOcorrencia
  UI --> Gestor : Confirmação
  
  opt Sub-fluxo UC04
    Gestor -> UI : Anexar evidências
  end
  
else Cenário Alternativo I: Consultar Ocorrência
  Gestor -> UI : Selecionar consultar
  UI --> Gestor : Exibir campo de busca e filtros
  Gestor -> UI : Informar critérios
  UI -> Ocorrencia : buscarComFiltro(criterios)
  Ocorrencia -> DB : query()
  DB --> Ocorrencia : listaResumida
  Ocorrencia --> UI : listaExibicao
  UI --> Gestor : Exibir lista resumida
  Gestor -> UI : Selecionar uma ocorrência
  UI -> Ocorrencia : carregarDetalhesCompletos()
  Ocorrencia -> DB : buscarDetalhes()
  DB --> Ocorrencia : dadosCompletos (Mídias, Planos)
  Ocorrencia --> UI : dados
  UI --> Gestor : Exibir detalhes completos
end
@enduml
