@startuml
skinparam monochrome true
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultFontSize 14
skinparam roundcorner 10
skinparam maxmessagesize 120

actor "GestorDeSeguranca" as Gestor
participant "UI: Menu Principal" as UI
participant "Funcionario" as Funcionario
participant "Certificacao" as Certificacao
participant "Treinamento" as Treinamento
database "Banco de Dados" as DB

Gestor -> UI : Acessar "Certificações e Treinamentos"
UI -> Funcionario : carregarFuncionarios()
Funcionario -> DB : buscarTodos()

alt Cenário de Exceção I: Falha BD
  DB --> Funcionario : Falha/Timeout
  Funcionario --> UI : erroConexao
  UI --> Gestor : Exibir erro de indisponibilidade
else Sucesso
  DB --> Funcionario : lista<Funcionario>
  loop Para cada funcionário
    Funcionario -> Funcionario : estaApto()
    Funcionario -> Certificacao : verificarVencimentos()
    Funcionario -> Treinamento : verificarPendencias()
  end
  Funcionario --> UI : listaEAlertas
  UI --> Gestor : Exibir listagem
  
  opt C. Alt I: Certificados Vencidos
    UI -> UI : emitirAlerta("Necessita renovação")
  end
  opt C. Alt II: Treinamentos Pendentes
    UI -> UI : emitirAlerta("Treinamento pendente")
  end
end

== Consultar Detalhes do Funcionário ==
Gestor -> UI : Selecionar funcionário (cpf)
UI -> Funcionario : obterDetalhesTreinamentos()
Funcionario -> DB : buscarCertificacoesETreinamentos(cpf)
DB --> Funcionario : detalhes

alt C. Alt III: Sem certificações
  Funcionario -> Funcionario : verificarExistencia()
  Funcionario --> UI : listaVazia
  UI --> Gestor : Exibir "Funcionário sem certificações cadastradas"
else Possui certificações
  Funcionario --> UI : dadosCompletos
  UI --> Gestor : Exibir detalhes das certificações e treinamentos
end
@enduml
